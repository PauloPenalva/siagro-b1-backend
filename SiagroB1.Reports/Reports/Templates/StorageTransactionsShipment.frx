    <Total Name="TotalServices" Expression="[StorageTransactions.ValorServicos]" Evaluator="Data1"/>
    <Total Name="TotalFreight" Expression="[StorageTransactions.Frete]" Evaluator="Data1"/>
  </Dictionary>
